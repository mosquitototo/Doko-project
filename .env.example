POSTGRES_DB=doko
POSTGRES_USER=doko_user
POSTGRES_PASSWORD="change_me"
POSTGRES_HOST=db
POSTGRES_PORT=5432

DOKO_HTTP_BIND=127.0.0.1
DOKO_HTTP_PORT=8080

DJANGO_DEBUG=0
DJANGO_SECRET_KEY=change_me
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_ALLOWED_HOSTS=doko.example.com,localhost,127.0.0.1

### remove http://localhost:8080,http://127.0.0.1:8080 for prod, then docker compose restart web nginx
DJANGO_CSRF_TRUSTED_ORIGINS=https://doko.example.com,http://localhost:8080,http://127.0.0.1:8080
DJANGO_CORS_ALLOWED_ORIGINS=https://doko.example.com,http://localhost:8080,http://127.0.0.1:8080

GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=300
